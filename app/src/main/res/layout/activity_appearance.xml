<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/my_background_9">

    <!-- Ambient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_transparent_black" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Appearance"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. DISPLAY MODE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theme Mode"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <RadioGroup
                    android:id="@+id/rgTheme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp">
                    <RadioButton android:id="@+id/rbLight" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Light" android:textColor="@color/white" android:buttonTint="@color/white"/>
                    <RadioButton android:id="@+id/rbDark" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Dark" android:textColor="@color/white" android:buttonTint="@color/white"/>
                    <RadioButton android:id="@+id/rbSystem" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Auto" android:textColor="@color/white" android:buttonTint="@color/white"/>
                </RadioGroup>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. WALLPAPERS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat Wallpapers"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">
                        <LinearLayout
                            android:id="@+id/llBackgroundList"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="4dp">
                            <!-- Items added in code -->
                        </LinearLayout>
                    </HorizontalScrollView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCustomBackground"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Select from Gallery"
                        style="@style/Widget.Material3.Button.TextButton"
                        app:icon="@android:drawable/ic_menu_gallery"
                        android:textColor="@color/white"
                        app:iconTint="@color/white"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. CHAT BUBBLES & FONT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chat &amp; Typography"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settingBubbleStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Chat Bubble Style"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:drawableStart="@android:drawable/stat_notify_chat"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/white" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_20"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Text Size"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>
                        <SeekBar
                            android:id="@+id/sbFontSize"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="2"
                            android:progress="1"
                            android:progressTint="@color/primary"
                            android:thumbTint="@color/primary"/>
                        <TextView
                            android:id="@+id/tvPreviewText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="This is how your messages will look."
                            android:textColor="@color/white_90"
                            android:textSize="16sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:alpha="0.8"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4. APP BRANDING -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="App Personalization"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/settingAccentColor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="Brand Accent Color"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:drawableStart="@android:drawable/ic_menu_manage"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/white" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_20"/>

                    <TextView
                        android:id="@+id/settingAppIcon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:text="App Launcher Icon"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:drawableStart="@android:drawable/ic_menu_compass"
                        android:drawablePadding="16dp"
                        android:drawableTint="@color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. VISUAL EFFECTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Advanced Effects"
                android:textColor="@color/secondary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/glass_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UI Motion &amp; Animations"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAnimations"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_20" android:layout_marginVertical="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Glassmorphism UI"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchGlassEffect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_20" android:layout_marginVertical="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Compact Chat List"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchCompactMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/white_20" android:layout_marginVertical="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show Profile Details"
                            android:textColor="@color/white"
                            android:textSize="16sp"/>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchMemberCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:checked="true"/>
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>