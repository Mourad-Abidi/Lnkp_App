<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC0D0D0D"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp"
    app:strokeColor="#1AFFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="6dp">

        <TextView
            android:id="@+id/menuViewProfile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="View Profile"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/menuMediaInfo"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Media Info"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/menuAutoDelete"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Auto-Delete: Off"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/menuMute"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Mute Notifications"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/menuSearch"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Search in Chat"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginVertical="4dp"
            android:background="#33FFFFFF" />

        <TextView
            android:id="@+id/menuClearChat"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Clear Chat History"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/menuDeleteChat"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Delete Chat"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>